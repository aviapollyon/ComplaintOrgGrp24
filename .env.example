# ── Application ───────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string

# ── Database (leave blank to use SQLite default) ──────────────
# DATABASE_URL=postgresql://user:pass@localhost/grievance

# ── Email / Flask-Mail ─────────────────────────────────────────
# Copy this file to .env and fill in the values below.
# Gmail requires an App Password (not your normal password):
#   Google Account → Security → 2-Step Verification → App passwords

MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-gmail-address@gmail.com
MAIL_PASSWORD=your-gmail-app-password
# MAIL_DEFAULT_SENDER defaults to MAIL_USERNAME if not set
# MAIL_DEFAULT_SENDER=DUT Grievance Portal <your-gmail-address@gmail.com>
# Set to true ONLY if you want to disable sending (e.g. unit tests)
# MAIL_SUPPRESS_SEND=false
