# Flask
FLASK_APP=run.py
FLASK_ENV=development

# Core app settings
SECRET_KEY=change-me-to-a-long-random-secret
# Leave empty to use default SQLite in instance/grievance.db
DATABASE_URL=

# Email (Flask-Mail / SMTP)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_DEBUG=false
MAIL_USERNAME=aviapollyonc@gmail.com
MAIL_PASSWORD=ubbahruwnnepalul
# If empty, app falls back to MAIL_USERNAME
MAIL_DEFAULT_SENDER=aviapollyonc@gmail.com
# true = do not send emails (useful for local testing)
MAIL_SUPPRESS_SEND=false

# Realtime transport (polling)
# Set false in constrained production environments if needed.
REALTIME_ENABLED=true
POLL_INTERVAL_SECONDS=10
POLL_TIMEOUT_SECONDS=8
POLL_MAX_BACKOFF_SECONDS=30
POLL_BATCH_LIMIT=20

# SLA monitor
SLA_MONITOR_ENABLED=true
SLA_MONITOR_INTERVAL_SECONDS=300
# NOTE: current config.py interprets this inverted: set false to enable SLA emails.
SLA_EMAIL_ENABLED=true
